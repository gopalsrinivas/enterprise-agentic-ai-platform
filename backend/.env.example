# Copy to .env for local development. Replace placeholders locally; never commit .env.
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://app_user:CHANGE_ME@localhost:5432/enterprise_agentic_ai
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_CONNECT_TIMEOUT_SECONDS=5
JWT_SECRET=CHANGE_ME_USE_AT_LEAST_32_RANDOM_CHARACTERS
JWT_ISSUER=enterprise-agentic-ai-platform
JWT_AUDIENCE=enterprise-agentic-ai-platform-api
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
REGISTRATION_ENABLED=false

# Uploaded content is untrusted. Keep this outside any public web root.
DOCUMENT_STORAGE_PATH=.data/documents
DOCUMENT_MAX_BYTES=10000000
DOCUMENT_MAX_PAGES=500
DOCUMENT_MAX_EXTRACTED_CHARS=2000000
DOCUMENT_CHUNK_CHARS=1200
DOCUMENT_CHUNK_OVERLAP_CHARS=200
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# OPENAI_API_KEY=configure-only-when-EMBEDDING_PROVIDER-is-openai
